<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title><%= content_for?(:title) ? yield(:title) : "PDF Report" %></title>
  <style>
    body {
      font-family: "Times New Roman", serif;
      padding: 40px;
      background-color: #f8f9fa;
    }
    .container {
      max-width: 800px;
      margin: auto;
      background: #ffffff;
      padding: 30px;
      border-radius: 10px;
      box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.1);
    }
    h1 {
      text-align: center;
      font-size: 28px;
      margin-bottom: 15px;
      color: #343a40;
    }
    .meta {
      font-size: 14px;
      color: #6c757d;
      text-align: center;
      margin-bottom: 15px;
    }
    .meta strong {
      color: #212529;
    }
    .footer {
      text-align: center;
      font-size: 12px;
      color: #6c757d;
      padding-top: 10px;
      border-top: 1px solid #dee2e6;
    }
  </style>
</head>
<body>
  <div class="container">
    <%= yield %>
  </div>
</body>
</html>
